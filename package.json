{
  "name": "fontplay",
  "version": "0.1.0",
  "description": "Upload a font, view glyphs as SVG, modify them with AI.",
  "type": "module",
  "imports": {
    "#shared/*": "./shared/*"
  },
  "scripts": {
    "build:wasm": "wasm-pack build rust --target web --out-dir ../src/wasm --out-name fontplay",
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vue-tsc && vite build",
    "preview": "vite preview",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "rollup": "^4.60.1",
    "vite-plugin-wasm": "^3.3.0",
    "vue-tsc": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@csstools/normalize.css": "^12.1.1",
    "@netlify/blobs": "^10.7.0",
    "vue": "^3.5.0"
  }
}
