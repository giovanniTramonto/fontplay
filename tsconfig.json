{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"],
      "#shared/*": ["./shared/*"]
    },
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": ["src/**/*", "shared/**/*", "netlify/**/*", "vite.config.ts"]
}
